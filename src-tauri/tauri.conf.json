{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkHub",
  "version": "1.0.5",
  "identifier": "com.workhub.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1487",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:workhub.db"
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNDNDRjdBOTZGNDY4MzAKUldRd2FQU1dlczlEZ1RBUGdWT2tqRllGQVpjdDc1Sm0ydm9RcWFIekxNZFhwcENQZk4xZlRIS3UK",
      "endpoints": [
        "https://github.com/YaLeiMa/WorkHub/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "WorkHub",
        "width": 900,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "center": true
      },
      {
        "label": "spotlight",
        "title": "WorkHub 搜索",
        "width": 480,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "dmg",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}